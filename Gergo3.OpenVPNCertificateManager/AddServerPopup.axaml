<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gergo3.OpenVPNCertificateManager"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Gergo3.OpenVPNCertificateManager.AddServerPopup"
        x:DataType="local:AddServerPopup"
        Title="AddServerPopup">
        <Grid ColumnDefinitions="* *"
              RowDefinitions="* * * * *"
              >
            <TextBox 
                     Grid.ColumnSpan="2"
                     Watermark="name"
                     Text="{Binding NameInput}"
                     />
            <TextBox 
                     Grid.ColumnSpan="2"
                     Grid.Row="1"
                     Watermark="domain"
                     Text="{Binding Domain}"
                     />
            <TextBox
                     Grid.ColumnSpan="2"
                     Grid.Row="2"
                     PasswordChar="*"
                     Watermark="password"
                     Text="{Binding Password}"
                     />
            <TextBox
                     Grid.ColumnSpan="2"
                     Grid.Row="3"
                     PasswordChar="*"
                     Watermark="password again"
                     Text="{Binding PasswordConfirmation}"
                     />
            <Button Grid.Column="0" 
                    Grid.Row="4"
                    Content="Ok"
                    Command="{Binding Ok}"
            />
            <Button Grid.Column="1"
                    Grid.Row="4"
                    Content="Cancel"
                    Command="{Binding Close}"
                    />
                
        </Grid>
</Window>
